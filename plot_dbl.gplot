set terminal png size 600,400
set key left top box box
unset logscale x
unset logscale y
set xrange [0:1e2]
set yrange [*:200]
set output 'enumerated_steps_vs_x_dbl_3.png'
set xlabel 'x_0'
set ylabel 'steps (m+d)'
plot 'double_enumerated.txt' using ($4/$5):($2+$3) \
