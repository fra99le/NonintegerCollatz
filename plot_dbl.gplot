set terminal png size 600,400
set key left top box box
set logscale x
set logscale y
set xrange [1e-2:1e5]
set yrange [1:1e3]
set output 'enumerated_steps_vs_x_dbl_2.png'
set xlabel 'x_0'
set ylabel 'steps (m+d)'
plot 'double_enumerated.txt' using ($4/$5):($2+$3) \
