set terminal png size 600,400
set key left top box
unset logscale x
unset logscale y
set xrange [0:1e2]
set yrange [*:200]
set output 'enumerated_steps_vs_x_dbl.png'
set xlabel 'x_0'
set ylabel 'steps (m+d)'
plot 'double_enumerated.txt' using ($4/$5):($2+$3) \
        linecolor rgb '#F5B63F' \
        with dots title 'x_0 (step size=1/32)', \
     'divfree_x_enumerated.txt' using ($4/$5):($2+$3) \
        linecolor rgb '#008ebc' \
        with points title 'Integer x_0';

