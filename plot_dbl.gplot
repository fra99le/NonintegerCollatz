#!/usr/bin/env gnuplot

set terminal png size 1600,1000
set encoding utf8
#set title ""

set key right bottom box

set mxtics 10
set grid x
set grid y

#set term wxt
#set logscale z
#set zrange [1:*]
#splot 'common_paths.txt' using 1:2:($3+$4-$5*2) palette z with dots;
#pause -1

set terminal png size 600,400
set logscale x
set logscale y
set xrange [1e-4:1e6]
set yrange [*:*]
#set output 'sampled_steps_vs_x_dbl.png'
set xlabel 'x_0'
set ylabel 'steps (m+d)'
#plot 'double_sampled.txt' using ($4/$5):($2+$3) \
        linecolor rgb '#F5B63F' \
        with dots title 'Sampled x (double)', \
     'divfree_w_sampled.txt' using ($4/$5):($2+$3) \
        linecolor rgb '#008ebc' \
        with dots title 'Sampled w', \
     'divfree_x_sampled.txt' using ($4/$5):($2+$3) \
        linecolor rgb '#008e00' \
        with dots title 'Integer x_0';

#set term pdf size 5in,3in
#set output "sampled_steps_vs_x_dbl.pdf"
#replot

set terminal png size 600,400
set key left top box
set logscale x
set logscale y
set xrange [0.01:1e5]
set yrange [0.01:*]
#set output 'sampled_w_vs_x_dbl.png'
set xlabel 'x_0'
set ylabel 'w'
#plot 'double_sampled.txt' using ($4/$5):1 \
        linecolor rgb '#F5B63F' \
        with dots title 'Sampled x (double)', \
     'divfree_w_sampled.txt' using ($4/$5):1 \
        linecolor rgb '#008ebc' \
        with dots title 'Sampled w', \
     'divfree_x_sampled.txt' using ($4/$5):1 \
        linecolor rgb '#0A49C0' \
        with dots title 'Integer x_0';

#set term pdf size 5in,3in
#set output "sampled_w_vs_x_dbl.pdf"
#replot

set terminal png size 600,400
set key left top box
set logscale x
set logscale y
set xrange [0.01:5e17]
set yrange [*:1e90]
