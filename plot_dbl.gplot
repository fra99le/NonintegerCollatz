        with points title 'Integer x_0', \
     'divfree_w_sampled.txt' using ($4/$5):($2+$3) \
        linecolor rgb '#38BD31' \
        with dots title 'Sampled w';

set term pdf size 5in,3in
set output "enumerated_steps_vs_x_dbl_3.pdf"
