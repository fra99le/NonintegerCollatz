#replot

set terminal png size 600,400
set key right bottom box
unset logscale x
set logscale y
set xrange [0:1e2]
set yrange [1e1:1e6]
#set output 'enumerated_w_vs_x_dbl.png'
set xlabel 'x_0'
set ylabel 'w'
#plot 'double_enumerated.txt' using ($4/$5):1 \
        linecolor rgb '#F5B63F' \
        with dots title 'x_0 (step size=1/32)', \
     'divfree_x_enumerated.txt' using ($4/$5):1 \
        linecolor rgb '#008ebc' \
        with points title 'Integer x_0';

#set term pdf size 5in,3in font "droidsans,12.0"
